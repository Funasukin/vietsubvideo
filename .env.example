# Copy thanh .env va dien gia tri

# Phase 1 — dich
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Phase 1 — TTS (edge-tts mien phi, khong can key; doi giong tai day)
TTS_VOICE=vi-VN-NamMinhNeural
# LUCYLAB_API_KEY=

# Cookie cho yt-dlp — CHI CAN khi tai/kiem tra video Bilibili (Bilibili chan 412
# neu thieu phien dang nhap). YouTube/Douyin khong can.
# Cach 1 (khuyen nghi, dung duoc ca khi trinh duyet dang mo): dang nhap
#   bilibili.com roi xuat cookies.txt bang tien ich "Get cookies.txt LOCALLY",
#   tro duong dan tuyet doi vao day:
# YTDLP_COOKIES_FILE=C:\Users\Admin\bilibili_cookies.txt
# Cach 2 (yt-dlp tu doc tu trinh duyet — PHAI DONG trinh duyet do truoc):
# YTDLP_COOKIES_BROWSER=edge

# Phase 2 — Telegram bot (tao bot qua @BotFather)
TELEGRAM_BOT_TOKEN=

# Phase 3 — upload
YT_CLIENT_SECRET_FILE=secrets/yt_client_secret.json
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# #8 Nhan dien NGUOI NOI tu audio that (diarization, pyannote) — casting theo nhan vat.
# Can: pip install pyannote.audio (khuyen nghi desktop GPU) + token HuggingFace
# (chap nhan dieu khoan model pyannote/segmentation-3.0 va speaker-diarization-3.1).
DIARIZE=0
HF_TOKEN=
# 0 = tu doan so nguoi noi; dat so cu the (vd 4) neu biet truoc de chinh xac hon
DIARIZE_MAX_SPK=0

# Tong giong theo audio goc (PLAN muc 11, muc 1): do cao do/toc do/do to giong goc
# tung cau -> chinh rate/pitch/volume edge-tts cho khop. 0 = tat.
PROSODY=1

# Nhan cam xuc khi dich (PLAN 11 muc 2 = A+B): Claude gan nhan gap/gian/buon/thitham
# -> edge chinh them rate/pitch/volume, viXTTS chon clip mau hop cam xuc. 0 = tat.
EMOTION=1

# PLAN 11 muc 3 (THU NGHIEM, mac dinh tat): ep DANG duong ngu dieu cau goc len giong
# doc bang Praat PSOLA (can: pip install praat-parselmouth). 1 = bat.
PROSODY_TRANSFER=0

# PLAN 11 C/D — TTS TRA PHI (an toan ban quyen de kiem tien; chon qua TTS_ENGINE):
# elevenlabs (~$22/th, giong nguoi nhat, da ngon ngu) | vbee | fpt (chi tieng Viet)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_NAM=pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_NU=21m00Tcm4TlvDq8ikWAM
VBEE_TOKEN=
VBEE_APP_ID=
VBEE_VOICE_NAM=hn_male_manhdung_news_48k-fhg
VBEE_VOICE_NU=hn_female_ngochuyen_full_48k-fhg
FPT_TTS_API_KEY=
FPT_VOICE_NAM=leminh
FPT_VOICE_NU=banmai

# Nhip phu de: 1 = cau gop (cho giong doc) duoc TACH hien thi theo dung nhip
# tung dong sub goc | 0 = hien ca cau gop (block dai). Giong doc khong doi.
SUB_SPLIT=1

# #16 Ngon ngu DICH lồng tieng + phu de (vi|en|zh|ja|ko|es|fr|id|th|pt).
# Khac "vi": dich + doc bang giong edge cua ngon ngu do; viXTTS/casting chi ap dung tieng Viet.
TARGET_LANG=vi

# --- Tinh nang moi (deu tuy chon, co the chinh trong tab Cau hinh) ---
# #14 Khu on truoc Whisper (1 = bat): loc on cho ASR nghe ro
DENOISE=0
# #18 Nhac Like/Dang ky overlay vai giay dau video (on = bat)
SUBSCRIBE=off
SUBSCRIBE_TEXT=Nho Like & Dang ky kenh nhe!
# #11 Telegram bao job xong/loi (dien ca token o tren + chat id)
TELEGRAM_CHAT_ID=
# #1 Dang YouTube: file OAuth client .json ban tao o Google Cloud (bat YouTube Data API v3)
YOUTUBE_CLIENT_SECRETS=
YOUTUBE_PRIVACY=private
